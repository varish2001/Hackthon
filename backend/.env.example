# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# DO NOT COMMIT THIS FILE TO GIT

# =========================================
# Sarvam Configuration
# =========================================
# Get your API key from: https://www.sarvam.ai/
# IMPORTANT: Keep this secret! Don't share it!
SARVAM_API_KEY=your_sarvam_api_key_here

# Optional: Override Sarvam base URL if your account uses a custom endpoint
SARVAM_BASE_URL=https://api.sarvam.ai/v1

# =========================================
# Server Configuration
# =========================================
# Port the server will run on (change if 5000 is in use)
PORT=5000

# Environment mode (development, production, testing)
NODE_ENV=development

# =========================================
# Optional: Add more configuration as needed
# =========================================
# DATABASE_URL=mongodb://localhost/sanskritisetu
# ADMIN_EMAIL=admin@sanskritisetu.com
# LOG_LEVEL=debug

