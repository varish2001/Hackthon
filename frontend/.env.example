# Frontend Environment Variables Example
# COPY THIS FILE TO .env

# =========================================
# Backend API Configuration
# =========================================
# Local Development
REACT_APP_API_URL=http://localhost:5000

# Staging/Testing
# REACT_APP_API_URL=http://staging-api.sanskritisetu.com

# Production
# REACT_APP_API_URL=https://api.sanskritisetu.com

# =========================================
# Optional: Add more configuration as needed
# =========================================
# REACT_APP_APP_NAME=SanskritiSetu
# REACT_APP_ANALYTICS_ID=UA-XXXXX
# REACT_APP_VERSION=1.0.0

